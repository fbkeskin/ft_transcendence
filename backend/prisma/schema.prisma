generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// --------------------------------------------------------
// 1. KULLANICI MODELİ
// --------------------------------------------------------
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  username  String   @unique
  password  String
  avatar    String?  @default("default.png")
  createdAt DateTime @default(now())

  // 2FA
  isTwoFactorEnabled Boolean @default(false)
  twoFactorSecret    String?

  // İstatistikler
  wins   Int @default(0)
  losses Int @default(0)
  level  Int @default(0)

  // OYUN İLİŞKİLERİ
  gamesAsPlayer1 Game[] @relation("Player1")
  gamesAsPlayer2 Game[] @relation("Player2")
  winnerOf       Game[] @relation("Winner")

  // ARKADAŞLIK İLİŞKİLERİ (Daha kontrol edilebilir yapı)
  sentRequests     Friendship[] @relation("Sender")
  receivedRequests Friendship[] @relation("Receiver")

  // TURNUVA İLİŞKİLERİ
  wonTournaments   Tournament[] @relation("TournamentWinner")
}

// --------------------------------------------------------
// 2. ARKADAŞLIK MODELİ (Yeni Tablo)
// --------------------------------------------------------
// Bu tablo sayesinde "İstek gönderildi", "Kabul edildi" durumlarını tutabilirsin.
model Friendship {
  id        Int      @id @default(autoincrement())
  
  senderId  Int
  sender    User     @relation("Sender", fields: [senderId], references: [id])
  
  receiverId Int
  receiver   User    @relation("Receiver", fields: [receiverId], references: [id])
  
  status    String   @default("PENDING") // PENDING, ACCEPTED, BLOCKED
  createdAt DateTime @default(now())

  @@unique([senderId, receiverId]) // Aynı kişi aynı kişiye 2 kere istek atamasın
}

// --------------------------------------------------------
// 3. TURNUVA MODELİ (Yeni Tablo - Subject Zorunluluğu)
// --------------------------------------------------------
model Tournament {
  id        Int      @id @default(autoincrement())
  name      String   // Örn: "Haftalık Turnuva"
  status    String   @default("PENDING") // PENDING, STARTED, FINISHED
  createdAt DateTime @default(now())

  // Kazanan (Opsiyonel, turnuva bitince dolar)
  winnerId  Int?
  winner    User?    @relation("TournamentWinner", fields: [winnerId], references: [id])

  // Bu turnuvaya ait maçlar
  games     Game[]
}

// --------------------------------------------------------
// 4. OYUN MODELİ (Güncellendi)
// --------------------------------------------------------
model Game {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  
  // Bu oyun bir turnuvanın parçası mı? (Opsiyonel)
  tournamentId Int?
  tournament   Tournament? @relation(fields: [tournamentId], references: [id])

  // Player 1 (Her zaman kayıtlı kullanıcı - SEN)
  player1Id Int
  player1   User     @relation("Player1", fields: [player1Id], references: [id])
  score1    Int

  // Player 2 (OPSİYONEL - Kayıtlı olmayabilir)
  player2Id Int?     // <--- Soru işareti ekledik (Nullable)
  player2   User?    @relation("Player2", fields: [player2Id], references: [id])
  score2    Int
  
  // Eğer player2 kayıtlı değilse (AI veya Guest) adını buraya yazarız
  guestName String?  // <--- YENİ ALAN (Örn: "Yapay Zeka" veya "Misafir")

  winnerId  Int?
  winner    User?    @relation("Winner", fields: [winnerId], references: [id])
}