generator client {
  provider = "prisma-client-js"
  // linux-musl yerine debian ekledik, native zaten senin bilgisayarın için
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// --------------------------------------------------------
// 1. KULLANICI MODELİ
// --------------------------------------------------------
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  username  String   @unique
  password  String
  avatar    String?  @default("default.png")
  createdAt DateTime @default(now())

  // 2FA
  isTwoFactorEnabled Boolean @default(false)
  twoFactorSecret    String?

  // İstatistikler
  wins   Int @default(0)
  losses Int @default(0)
  level  Int @default(0)

  // OYUN İLİŞKİLERİ
  gamesAsPlayer1 Game[] @relation("Player1")
  gamesAsPlayer2 Game[] @relation("Player2")
  winnerOf       Game[] @relation("Winner")

  // ARKADAŞLIK İLİŞKİLERİ
  sentRequests     Friendship[] @relation("Sender")
  receivedRequests Friendship[] @relation("Receiver")

  // TURNUVA İLİŞKİLERİ
  tournaments Tournament[] 
}

// --------------------------------------------------------
// 2. ARKADAŞLIK MODELİ
// --------------------------------------------------------
model Friendship {
  id        Int      @id @default(autoincrement())
  
  senderId  Int
  sender    User     @relation("Sender", fields: [senderId], references: [id])
  
  receiverId Int
  receiver   User     @relation("Receiver", fields: [receiverId], references: [id])
  
  status    String   @default("PENDING") // PENDING, ACCEPTED, BLOCKED
  createdAt DateTime @default(now())

  @@unique([senderId, receiverId])
}

// --------------------------------------------------------
// 3. TURNUVA MODELİ
// --------------------------------------------------------
model Tournament {
  id        Int      @id @default(autoincrement())
  
  userId    Int      // Turnuvayı düzenleyen (Host)
  user      User     @relation(fields: [userId], references: [id])
  
  player1   String   // Katılımcı isimleri (Alias)
  player2   String
  player3   String
  player4   String
  
  winner    String   // Şampiyonun ismi
  
  // --- EKLENEN KISIM BURASI ---
  // Game modelinde tournamentId olduğu için burada da games olmalı.
  games     Game[]   

  createdAt DateTime @default(now())
}

// --------------------------------------------------------
// 4. OYUN MODELİ
// --------------------------------------------------------
model Game {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  
  // Bu oyun bir turnuvanın parçası mı?
  tournamentId Int?
  tournament   Tournament? @relation(fields: [tournamentId], references: [id])

  // Player 1 (Her zaman kayıtlı kullanıcı - SEN)
  player1Id Int
  player1   User     @relation("Player1", fields: [player1Id], references: [id])
  score1    Int

  // Player 2 (OPSİYONEL - Kayıtlı olmayabilir)
  player2Id Int?     
  player2   User?    @relation("Player2", fields: [player2Id], references: [id])
  score2    Int
  
  // Eğer player2 kayıtlı değilse (AI veya Guest) adını buraya yazarız
  guestName String?  

  winnerId  Int?
  winner    User?    @relation("Winner", fields: [winnerId], references: [id])
}