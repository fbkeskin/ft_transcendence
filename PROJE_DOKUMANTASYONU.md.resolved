## 💾 Veritabanı Şeması

### Prisma Schema (schema.prisma)

```prisma
// User Model
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  username  String   @unique
  password  String
  avatar    String?  @default("default.png")
  createdAt DateTime @default(now())

  // 2FA
  isTwoFactorEnabled Boolean @default(false)
  twoFactorSecret    String?

  // Stats
  wins   Int @default(0)
  losses Int @default(0)
  level  Int @default(1)

  // Relations
  gamesAsPlayer1 Game[] @relation("Player1")
  gamesAsPlayer2 Game[] @relation("Player2")
  winnerOf       Game[] @relation("Winner")
  
  sentRequests     Friendship[] @relation("Sender")
  receivedRequests Friendship[] @relation("Receiver")
  
  wonTournaments   Tournament[] @relation("TournamentWinner")
}

// Friendship Model
model Friendship {
  id         Int      @id @default(autoincrement())
  senderId   Int
  sender     User     @relation("Sender", fields: [senderId], references: [id])
  receiverId Int
  receiver   User     @relation("Receiver", fields: [receiverId], references: [id])
  status     String   @default("PENDING") // PENDING, ACCEPTED, BLOCKED
  createdAt  DateTime @default(now())

  @@unique([senderId, receiverId])
}

// Tournament Model
model Tournament {
  id        Int      @id @default(autoincrement())
  name      String
  status    String   @default("PENDING") // PENDING, STARTED, FINISHED
  createdAt DateTime @default(now())
  winnerId  Int?
  winner    User?    @relation("TournamentWinner", fields: [winnerId], references: [id])
  games     Game[]
}

// Game Model
model Game {
  id           Int         @id @default(autoincrement())
  createdAt    DateTime    @default(now())
  tournamentId Int?
  tournament   Tournament? @relation(fields: [tournamentId], references: [id])
  
  player1Id Int
  player1   User @relation("Player1", fields: [player1Id], references: [id])
  score1    Int
  
  player2Id Int?     // Nullable (AI için)
  player2   User?    @relation("Player2", fields: [player2Id], references: [id])
  score2    Int
  guestName String?  // "Yapay Zeka" veya "Misafir"
  
  winnerId  Int?
  winner    User? @relation("Winner", fields: [winnerId], references: [id])
}
```

### İlişki Diyagramı:

```mermaid
erDiagram
    User ||--o{ Game : "plays as P1"
    User ||--o{ Game : "plays as P2"
    User ||--o{ Game : "wins"
    User ||--o{ Friendship : "sends"
    User ||--o{ Friendship : "receives"
    User ||--o{ Tournament : "wins"
    Tournament ||--o{ Game : "contains"
    
    User {
        int id PK
        string email UK
        string username UK
        string password
        string avatar
        boolean isTwoFactorEnabled
        string twoFactorSecret
        int wins
        int losses
        int level
    }
    
    Game {
        int id PK
        int player1Id FK
        int player2Id FK "nullable"
        int score1
        int score2
        string guestName "nullable"
        int winnerId FK "nullable"
        int tournamentId FK "nullable"
    }
    
    Friendship {
        int id PK
        int senderId FK
        int receiverId FK
        string status
    }
    
    Tournament {
        int id PK
        string name
        string status
        int winnerId FK "nullable"
    }
```

